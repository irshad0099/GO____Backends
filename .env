REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Upstash Redis (Alternative)
UPSTASH_REDIS_URL=rediss://default:AUinAAIncDI1OTAzYzliZDNjZTc0MTM2YTUyY2ZmZTYzNDc0MTMyYXAyMTg1OTk@rare-scorpion-18599.upstash.io:6379

# ===============================
# JWT AUTH
# ===============================
JWT_SECRET=gomobility_super_secret_key
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_SECRET=gomobility_refresh_secret
JWT_REFRESH_EXPIRY=30d

# ===============================
# OTP / SMS CONFIG
# ===============================
OTP_EXPIRY_MINUTES=5
OTP_LENGTH=4
OTP_MAX_ATTEMPTS=3

# SMS Provider (MSG91)
SMS_PROVIDER=msg91
MSG91_AUTH_KEY=PUT_REAL_AUTH_KEY_HERE
MSG91_TEMPLATE_ID=699049811ff8cf33e001aeed
MSG91_SENDER_ID=GOMOBI

# Twilio (Alternative SMS Provider)
TWILIO_ACCOUNT_SID=xxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxx
TWILIO_PHONE_NUMBER=+91XXXXXXXXXX

# ===============================
# PAYMENT GATEWAY (RAZORPAY)
# ===============================
PAYMENT_GATEWAY=razorpay
RAZORPAY_KEY_ID=rzp_test_SC7bG4eoECRINy
RAZORPAY_KEY_SECRET=0Cbk3QIptL3En33ofS1zrZav
RAZORPAY_WEBHOOK_SECRET=gomobility_webhook_secret

# ===============================
# SUBSCRIPTION SETTINGS
# ===============================
DEFAULT_SUBSCRIPTION_CURRENCY=INR
FREE_TRIAL_DAYS=0

# ===============================
# SOCKET.IO CONFIG
# ===============================
SOCKET_PING_TIMEOUT=60000
SOCKET_PING_INTERVAL=25000

# ===============================
# GEO / LOCATION
# ===============================
DRIVER_SEARCH_RADIUS_METERS=5000
MAX_DRIVER_PING=5
LOCATION_UPDATE_INTERVAL=5
DEFAULT_SEARCH_RADIUS_KM=5

# ===============================
# SURGE PRICING
# ===============================
SURGE_BASE_MULTIPLIER=1.0
SURGE_MAX_MULTIPLIER=2.5
SURGE_DEMAND_THRESHOLD=10

# ===============================
# RATE LIMITING
# ===============================
RATE_LIMIT_WINDOW=900000  # 15 minutes in milliseconds
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5
OTP_RATE_LIMIT_MAX=3

# ===============================
# FILE UPLOAD / DOCUMENTS
# ===============================
UPLOAD_PROVIDER=local
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5
MAX_FILE_SIZE=5242880  # 5MB in bytes

# ===============================
# SECURITY
# ===============================
BCRYPT_SALT_ROUNDS=10
ENCRYPTION_KEY=gomobility_ultra_secure_key_2026
CORS_ORIGIN=*

# ===============================
# OCR (Driver Verification)
# ===============================
OCR_PROVIDER=aws_textract
AWS_ACCESS_KEY_ID=xxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxx
AWS_REGION=ap-south-1

# ===============================
# EMAIL CONFIG
# ===============================
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=yourmail@gmail.com
SMTP_PASS=yourpassword
EMAIL_FROM=GoMobility <noreply@gomobility.com>

# ===============================
# LOGGING
# ===============================
LOG_LEVEL=debug
LOG_FILE=logs/app.log

# ===============================
# MYSQL CONFIG (Optional - if using MySQL)
# ===============================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=gomobility
MYSQL_USER=root
MYSQL_PASSWORD=root123

# ===============================
# VEHICLE TYPES & PRICING
# ===============================
VEHICLE_TYPES=bike,auto,car
BIKE_BASE_FARE=20
BIKE_PER_KM=8
BIKE_PER_MINUTE=1
BIKE_MINIMUM_FARE=25
BIKE_SURGE_MULTIPLIER=1.5

AUTO_BASE_FARE=30
AUTO_PER_KM=12
AUTO_PER_MINUTE=1.5
AUTO_MINIMUM_FARE=35
AUTO_SURGE_MULTIPLIER=1.5

CAR_BASE_FARE=50
CAR_PER_KM=15
CAR_PER_MINUTE=2
CAR_MINIMUM_FARE=60
CAR_SURGE_MULTIPLIER=2.0

# ===============================
# CANCELLATION POLICIES
# ===============================
FREE_CANCELLATION_MINUTES=5
PASSENGER_CANCELLATION_FEE=10
DRIVER_CANCELLATION_PENALTY=20

# ===============================
# PAGINATION
# ===============================
PAGINATION_DEFAULT_LIMIT=20
PAGINATION_MAX_LIMIT=100