# GoMobility environment template

# Server
NODE_ENV=development
APP_NAME=GoMobility
PORT=5000
BASE_URL=http://localhost:5000
API_PREFIX=/api/v1

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=go_app
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_POOL_MAX=20
DB_POOL_IDLE=10000
DB_POOL_CONNECTION=10000

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
UPSTASH_REDIS_URL=

# JWT
JWT_SECRET=your_jwt_secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_SECRET=your_jwt_refresh_secret
JWT_REFRESH_EXPIRY=30d

# OTP
OTP_EXPIRY_MINUTES=5
OTP_LENGTH=4
OTP_MAX_ATTEMPTS=3

# SMS provider
SMS_PROVIDER=console
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Payments
PAYMENT_GATEWAY=razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
DEFAULT_SUBSCRIPTION_CURRENCY=INR
FREE_TRIAL_DAYS=0

# Socket
SOCKET_PING_TIMEOUT=60000
SOCKET_PING_INTERVAL=25000

# Geo / location
DRIVER_SEARCH_RADIUS_METERS=5000
DEFAULT_SEARCH_RADIUS_KM=5
MAX_DRIVER_PING=5
LOCATION_UPDATE_INTERVAL=5

# Surge pricing
SURGE_MAX_MULTIPLIER=1.75
PEAK_RATIO_THRESHOLD=1.2
PEAK_VELOCITY_THRESHOLD=18
DEMAND_WINDOW_MINUTES=10
VELOCITY_WINDOW_MINUTES=5
MIN_DEMAND_REQUESTS=5
PEAK_HOURS_MORNING_START=8
PEAK_HOURS_MORNING_END=10
PEAK_HOURS_EVENING_START=18
PEAK_HOURS_EVENING_END=21

# Weather
OPENWEATHER_API_KEY=
WEATHER_CACHE_MINUTES=15
WEATHER_PEAK_CONDITIONS=Rain,Drizzle,Thunderstorm,Snow,Squall,Tornado
WEATHER_SEVERE_CONDITIONS=Thunderstorm,Snow,Squall,Tornado
WEATHER_SURGE_MILD=1.1
WEATHER_SURGE_SEVERE=1.25

# Rate limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5
OTP_RATE_LIMIT_MAX=3

# File upload
UPLOAD_PROVIDER=local
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5
MAX_FILE_SIZE=5242880

# Security
BCRYPT_SALT_ROUNDS=10
ENCRYPTION_KEY=your_encryption_key
CORS_ORIGIN=*

# OCR / AWS
OCR_PROVIDER=aws_textract
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_BUCKET_NAME=

# Email
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="GoMobility <noreply@gomobility.com>"

# Logging
LOG_LEVEL=debug
LOG_FILE=logs/app.log

# Optional MySQL values
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_DB=
MYSQL_USER=
MYSQL_PASSWORD=

# Vehicle pricing
VEHICLE_TYPES=bike,auto,car
BIKE_BASE_FARE=20
BIKE_PER_KM=8
BIKE_MINIMUM_FARE=35
AUTO_BASE_FARE=30
AUTO_PER_KM=12
AUTO_MINIMUM_FARE=50
CAR_BASE_FARE=50
CAR_PER_KM=15
CAR_MINIMUM_FARE=90

# Average speed per vehicle
SPEED_BIKE=30
SPEED_AUTO=25
SPEED_CAR=35

# Platform fee
PLATFORM_FEE_BIKE=1
PLATFORM_FEE_AUTO=1.5
PLATFORM_FEE_CAR=5
PLATFORM_FEE_DAILY_CAP=10

# Waiting charges
WAITING_GRACE_MINUTES=3
WAITING_RATE_BIKE=1
WAITING_RATE_AUTO=1.5
WAITING_RATE_CAR=2

# Traffic compensation
TRAFFIC_GRACE_BUFFER_MINUTES=30
TRAFFIC_RATE_BIKE=0.5
TRAFFIC_RATE_AUTO=1
TRAFFIC_RATE_CAR=1.5

# Pickup compensation
PICKUP_BASE_RADIUS_KM=2.5
PICKUP_COMP_BIKE=3
PICKUP_COMP_AUTO=5
PICKUP_COMP_CAR=7

# Convenience fee
CONV_FEE_BIKE_NONPEAK_MIN=5
CONV_FEE_BIKE_NONPEAK_MAX=5
CONV_FEE_BIKE_PEAK_MIN=10
CONV_FEE_BIKE_PEAK_MAX=12
CONV_FEE_AUTO_NONPEAK_MIN=12
CONV_FEE_AUTO_NONPEAK_MAX=15
CONV_FEE_AUTO_PEAK_MIN=20
CONV_FEE_AUTO_PEAK_MAX=25
CONV_FEE_CAR_NONPEAK_MIN=20
CONV_FEE_CAR_NONPEAK_MAX=25
CONV_FEE_CAR_PEAK_MIN=30
CONV_FEE_CAR_PEAK_MAX=50

# Cancellation
CANCELLATION_PENALTY=50
CANCELLATION_DISTANCE_THRESHOLD=500
CANCELLATION_DRIVER_SHARE_PERCENT=80
CANCELLATION_PLATFORM_SHARE_PERCENT=20

# Pagination
PAGINATION_DEFAULT_LIMIT=20
PAGINATION_MAX_LIMIT=100