{
	"info": {
		"name": "GoMobility API",
		"description": "Complete API collection for GoMobility ride-hailing backend.\n\nBase URL: http://localhost:5000/api/v1\n\nFlow:\n1. Signup -> Verify Signup -> Get Token\n2. Signin -> Verify Signin -> Get Token\n3. Use token in all authenticated requests\n\nRoles: passenger, driver, admin",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:5000/api/v1"
		},
		{
			"key": "accessToken",
			"value": ""
		},
		{
			"key": "refreshToken",
			"value": ""
		}
	],
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{accessToken}}",
				"type": "string"
			}
		]
	},
	"item": [
		{
			"name": "Auth",
			"description": "Authentication endpoints - OTP based signup/signin",
			"item": [
				{
					"name": "Signup (Send OTP)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"phone\": \"9876543210\",\n    \"email\": \"akash@example.com\",\n    \"fullName\": \"Akash Kumar\",\n    \"role\": \"passenger\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/auth/signup",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "signup"]
						}
					},
					"response": []
				},
				{
					"name": "Verify Signup (Verify OTP)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.data && jsonData.data.accessToken) {",
									"    pm.collectionVariables.set('accessToken', jsonData.data.accessToken);",
									"    pm.collectionVariables.set('refreshToken', jsonData.data.refreshToken);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"phone\": \"9876543210\",\n    \"otp\": \"123456\",\n    \"email\": \"akash@example.com\",\n    \"fullName\": \"Akash Kumar\",\n    \"role\": \"passenger\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/auth/verify-signup",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "verify-signup"]
						}
					},
					"response": []
				},
				{
					"name": "Signin (Send OTP)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"phone\": \"9876543210\",\n    \"role\": \"passenger\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/auth/signin",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "signin"]
						}
					},
					"response": []
				},
				{
					"name": "Verify Signin (Verify OTP)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.data && jsonData.data.accessToken) {",
									"    pm.collectionVariables.set('accessToken', jsonData.data.accessToken);",
									"    pm.collectionVariables.set('refreshToken', jsonData.data.refreshToken);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"phone\": \"9876543210\",\n    \"otp\": \"123456\",\n    \"role\": \"passenger\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/auth/verify-signin",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "verify-signin"]
						}
					},
					"response": []
				},
				{
					"name": "Refresh Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.data && jsonData.data.accessToken) {",
									"    pm.collectionVariables.set('accessToken', jsonData.data.accessToken);",
									"    pm.collectionVariables.set('refreshToken', jsonData.data.refreshToken);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"refreshToken\": \"{{refreshToken}}\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/auth/refresh-token",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "refresh-token"]
						}
					},
					"response": []
				},
				{
					"name": "Logout",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"refreshToken\": \"{{refreshToken}}\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/auth/logout",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "logout"]
						}
					},
					"response": []
				},
				{
					"name": "Get Current User (Me)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/auth/me",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "me"]
						}
					},
					"response": []
				}
			]
		},
