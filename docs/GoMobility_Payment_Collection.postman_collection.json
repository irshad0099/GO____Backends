{
  "info": {
    "name": "GoMobility — Payment Testing (Full)",
    "description": "Passenger + Driver side — sabhi payment methods ka complete test flow",
    "_postman_id": "gomobility-payment-v1",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "BASE_URL",        "value": "https://api.gomobility.co.in/api/v1", "type": "string" },
    { "key": "DRIVER_TOKEN",    "value": "PASTE_DRIVER_TOKEN_HERE",             "type": "string" },
    { "key": "PASSENGER_TOKEN", "value": "PASTE_PASSENGER_TOKEN_HERE",          "type": "string" },
    { "key": "RIDE_ID",         "value": "",                                     "type": "string" },
    { "key": "ORDER_NUMBER",    "value": "",                                     "type": "string" }
  ],
  "item": [

    {
      "name": "🔑 1. AUTH",
      "item": [
        {
          "name": "Passenger — Send OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{BASE_URL}}/auth/send-otp", "host": ["{{BASE_URL}}"], "path": ["auth","send-otp"] },
            "body": { "mode": "raw", "raw": "{\n  \"phone\": \"9876543210\"\n}" }
          }
        },
        {
          "name": "Passenger — Verify OTP → Save Token",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "var res = pm.response.json();",
              "if(res.data && res.data.accessToken){",
              "  pm.collectionVariables.set('PASSENGER_TOKEN', res.data.accessToken);",
              "  console.log('✅ Passenger token saved');",
              "}"
            ]}
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{BASE_URL}}/auth/verify-otp", "host": ["{{BASE_URL}}"], "path": ["auth","verify-otp"] },
            "body": { "mode": "raw", "raw": "{\n  \"phone\": \"9876543210\",\n  \"otp\": \"XXXX\"\n}" }
          }
        },
        {
          "name": "Driver — Send OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{BASE_URL}}/auth/send-otp", "host": ["{{BASE_URL}}"], "path": ["auth","send-otp"] },
            "body": { "mode": "raw", "raw": "{\n  \"phone\": \"9200000001\"\n}" }
          }
        },
        {
          "name": "Driver — Verify OTP → Save Token",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "var res = pm.response.json();",
              "if(res.data && res.data.accessToken){",
              "  pm.collectionVariables.set('DRIVER_TOKEN', res.data.accessToken);",
              "  console.log('✅ Driver token saved');",
              "}"
            ]}
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{BASE_URL}}/auth/verify-otp", "host": ["{{BASE_URL}}"], "path": ["auth","verify-otp"] },
            "body": { "mode": "raw", "raw": "{\n  \"phone\": \"9200000001\",\n  \"otp\": \"XXXX\"\n}" }
          }
        }
      ]
    },

    {
      "name": "⚙️ 2. DRIVER SETUP",
      "item": [
        {
          "name": "Driver — Go Online",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{DRIVER_TOKEN}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": { "raw": "{{BASE_URL}}/drivers/availability", "host": ["{{BASE_URL}}"], "path": ["drivers","availability"] },
            "body": { "mode": "raw", "raw": "{\n  \"isAvailable\": true,\n  \"latitude\": 28.6315,\n  \"longitude\": 77.2167\n}" }
          }
        },
        {
          "name": "Driver — Go Offline",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{DRIVER_TOKEN}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": { "raw": "{{BASE_URL}}/drivers/availability", "host": ["{{BASE_URL}}"], "path": ["drivers","availability"] },
            "body": { "mode": "raw", "raw": "{\n  \"isAvailable\": false,\n  \"latitude\": 28.6315,\n  \"longitude\": 77.2167\n}" }
          }
        },
        {
          "name": "Driver — Update Location",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{DRIVER_TOKEN}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": { "raw": "{{BASE_URL}}/drivers/location", "host": ["{{BASE_URL}}"], "path": ["drivers","location"] },
            "body": { "mode": "raw", "raw": "{\n  \"latitude\": 28.6315,\n  \"longitude\": 77.2167\n}" }
          }
        },
        {
          "name": "Driver — Get Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{DRIVER_TOKEN}}" }],
            "url": { "raw": "{{BASE_URL}}/drivers/profile", "host": ["{{BASE_URL}}"], "path": ["drivers","profile"] }
          }
        },
        {
          "name": "Driver — Save FCM Token",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{DRIVER_TOKEN}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": { "raw": "{{BASE_URL}}/drivers/fcm-token", "host": ["{{BASE_URL}}"], "path": ["drivers","fcm-token"] },
            "body": { "mode": "raw", "raw": "{\n  \"fcm_token\": \"TEST_FCM_TOKEN_123\"\n}" }
          }
        }
      ]
    },

    {
      "name": "💵 3. CASH PAYMENT FLOW",
      "item": [
        {
          "name": "STEP 1 — Passenger: Request Ride (cash)",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "var res = pm.response.json();",
              "if(res.data && res.data.rideId){",
              "  pm.collectionVariables.set('RIDE_ID', res.data.rideId);",
              "  console.log('✅ RIDE_ID saved:', res.data.rideId);",
              "}"
            ]}
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{PASSENGER_TOKEN}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": { "raw": "{{BASE_URL}}/rides/request", "host": ["{{BASE_URL}}"], "path": ["rides","request"] },
            "body": { "mode": "raw", "raw": "{\n  \"pickupLatitude\": 28.6315,\n  \"pickupLongitude\": 77.2167,\n  \"dropLatitude\": 28.5355,\n  \"dropLongitude\": 77.3910,\n  \"pickupAddress\": \"Connaught Place, Delhi\",\n  \"dropoffAddress\": \"Noida Sector 62\",\n  \"vehicleType\": \"bike\",\n  \"paymentMethod\": \"cash\"\n}" }
          }
        },
        {
          "name": "STEP 2 — Driver: Accept Ride",
          "request": {
            "method": "POST",
