              { "key": "Authorization", "value": "Bearer {{DRIVER_TOKEN}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": { "raw": "{{BASE_URL}}/rides/{{RIDE_ID}}/status", "host": ["{{BASE_URL}}"], "path": ["rides","{{RIDE_ID}}","status"] },
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"arrived\"\n}" }
          }
        },
        {
          "name": "STEP 4 — Driver: Generate OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{DRIVER_TOKEN}}" }],
            "url": { "raw": "{{BASE_URL}}/rides/{{RIDE_ID}}/generate-otp", "host": ["{{BASE_URL}}"], "path": ["rides","{{RIDE_ID}}","generate-otp"] }
          }
        },
        {
          "name": "STEP 5 — Driver: Verify OTP",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{DRIVER_TOKEN}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": { "raw": "{{BASE_URL}}/rides/{{RIDE_ID}}/verify-otp", "host": ["{{BASE_URL}}"], "path": ["rides","{{RIDE_ID}}","verify-otp"] },
            "body": { "mode": "raw", "raw": "{\n  \"otp\": \"XXXX\"\n}" }
          }
        },
        {
          "name": "STEP 6 — Driver: Status = completed",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{DRIVER_TOKEN}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": { "raw": "{{BASE_URL}}/rides/{{RIDE_ID}}/status", "host": ["{{BASE_URL}}"], "path": ["rides","{{RIDE_ID}}","status"] },
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"completed\"\n}" }
          }
        },
        {
          "name": "STEP 7 — Driver: Collect Confirm (cash) ⭐",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{DRIVER_TOKEN}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": { "raw": "{{BASE_URL}}/rides/{{RIDE_ID}}/collect-confirm", "host": ["{{BASE_URL}}"], "path": ["rides","{{RIDE_ID}}","collect-confirm"] },
            "body": { "mode": "raw", "raw": "{\n  \"method\": \"cash\"\n}" }
          }
        },
        {
          "name": "STEP 8 — Driver: Check Cash Balance ⭐",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{DRIVER_TOKEN}}" }],
            "url": { "raw": "{{BASE_URL}}/drivers/cash/balance", "host": ["{{BASE_URL}}"], "path": ["drivers","cash","balance"] }
          }
        },
        {
          "name": "STEP 9 — Driver: Submit Deposit ⭐",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{DRIVER_TOKEN}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": { "raw": "{{BASE_URL}}/drivers/cash/deposit", "host": ["{{BASE_URL}}"], "path": ["drivers","cash","deposit"] },
            "body": { "mode": "raw", "raw": "{\n  \"amount\": 10,\n  \"deposit_method\": \"upi\",\n  \"reference_number\": \"TEST-UPI-001\",\n  \"deposit_proof\": null\n}" }
          }
        },
        {
          "name": "STEP 10 — Driver: Verify Wallet Balance ⭐",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{DRIVER_TOKEN}}" }],
            "url": { "raw": "{{BASE_URL}}/wallet/balance", "host": ["{{BASE_URL}}"], "path": ["wallet","balance"] }
          }
        },
        {
          "name": "Driver: Deposit History",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{DRIVER_TOKEN}}" }],
            "url": { "raw": "{{BASE_URL}}/drivers/cash/deposits", "host": ["{{BASE_URL}}"], "path": ["drivers","cash","deposits"] }
          }
        },
        {
          "name": "Driver: Trip Summary",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{DRIVER_TOKEN}}" }],
            "url": { "raw": "{{BASE_URL}}/rides/{{RIDE_ID}}/driver-summary", "host": ["{{BASE_URL}}"], "path": ["rides","{{RIDE_ID}}","driver-summary"] }
          }
        }
      ]
    },

