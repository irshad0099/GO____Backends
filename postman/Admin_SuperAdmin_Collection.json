{
  "info": {
    "name": "GoMobility — Admin & Super Admin APIs",
    "_postman_id": "gomobility-admin-v1",
    "description": "Complete Admin & Super Admin API collection for GoMobility backend.\n\nBase URL: {{base_url}}/api/v1\n\nAuth: All routes need  →  Authorization: Bearer {{admin_token}}\n\nRole required: 'admin' OR 'super_admin'",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",    "value": "http://localhost:3000",  "type": "string" },
    { "key": "admin_token", "value": "PASTE_ACCESS_TOKEN_HERE","type": "string" }
  ],
  "item": [

    {
      "name": "1. Auth — Admin Login",
      "description": "OTP-based login for admin / super_admin. Two-step flow.",
      "item": [

        {
          "name": "1.1 Send OTP (Admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/v1/auth/send-otp", "host": ["{{base_url}}"], "path": ["api","v1","auth","send-otp"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"0000000001\",\n  \"role\": \"super_admin\"\n}"
            }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"statuscode\": 200,\n  \"message\": \"OTP sent successfully\",\n  \"data\": {\n    \"otp\": \"1234\"\n  }\n}"
            }
          ]
        },

        {
          "name": "1.2 Verify OTP (Admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/v1/auth/verify-otp", "host": ["{{base_url}}"], "path": ["api","v1","auth","verify-otp"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"0000000001\",\n  \"otp\": \"1234\",\n  \"role\": \"super_admin\"\n}"
            }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"statuscode\": 200,\n  \"message\": \"Login successful\",\n  \"data\": {\n    \"accessToken\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n    \"refreshToken\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n    \"user\": {\n      \"id\": \"uuid-here\",\n      \"phone_number\": \"0000000001\",\n      \"email\": \"ag244834@gmail.com\",\n      \"full_name\": \"GoMobility Super Admin\",\n      \"role\": \"super_admin\",\n      \"is_verified\": true,\n      \"is_active\": true\n    }\n  }\n}"
            }
          ]
        },

        {
          "name": "1.3 Send OTP (Regular Admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/v1/auth/send-otp", "host": ["{{base_url}}"], "path": ["api","v1","auth","send-otp"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"0000000002\",\n  \"role\": \"admin\"\n}"
            }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"statuscode\": 200,\n  \"message\": \"OTP sent successfully\",\n  \"data\": {\n    \"otp\": \"5678\"\n  }\n}"
            }
          ]
        },

        {
          "name": "1.4 Verify OTP (Regular Admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/v1/auth/verify-otp", "host": ["{{base_url}}"], "path": ["api","v1","auth","verify-otp"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"0000000002\",\n  \"otp\": \"5678\",\n  \"role\": \"admin\"\n}"
            }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"statuscode\": 200,\n  \"message\": \"Login successful\",\n  \"data\": {\n    \"accessToken\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n    \"refreshToken\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n    \"user\": {\n      \"id\": \"uuid-here\",\n      \"phone_number\": \"0000000002\",\n      \"email\": \"admin@gomobility.co.in\",\n      \"full_name\": \"GoMobility Admin\",\n      \"role\": \"admin\",\n      \"is_verified\": true,\n      \"is_active\": true\n    }\n  }\n}"
            }
          ]
        }

      ]
    },

