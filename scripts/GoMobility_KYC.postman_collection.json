{
  "info": {
    "name": "GoMobility — KYC (Cashfree Sandbox)",
    "_postman_id": "gomobility-kyc-v2",
    "description": "Actual code se nikala hua — exact field names, validators ke hisab se.\n\n⚠️ KYC sirf DRIVER ke liye hai — passenger token se saare /kyc/* routes 403 denge.\n\nFlow:\n1. Signup (role=driver) → Verify Signup (token auto-set)\n2. KYC requests chalao\n\nServer: npm run dev",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",       "value": "http://localhost:5000/api/v1", "type": "string" },
    { "key": "access_token",   "value": "", "type": "string" },
    { "key": "refresh_token",  "value": "", "type": "string" },
    { "key": "aadhaar_ref_id", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "AUTH",
      "item": [
        {
          "name": "Signup",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('200 OK', () => pm.response.to.have.status(200));",
                "const j = pm.response.json();",
                "pm.test('success true', () => pm.expect(j.success).to.be.true);",
                "console.log('OTP bheja gaya. Server logs mein OTP dekho (SMS_PROVIDER=console hai).');"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"9876543210\",\n  \"fullName\": \"Test Driver\",\n  \"role\": \"driver\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/auth/signup", "host": ["{{base_url}}"], "path": ["auth","signup"] },
            "description": "KYC sirf driver ke liye hai — role=driver use karo.\nFields (validator se):\n- phone: 10-digit Indian (6-9 se shuru)\n- fullName: optional, 2-100 chars\n- email: optional\n- role: passenger | driver | admin"
          }
        },
        {
          "name": "Verify Signup → TOKEN SET",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('200 OK', () => pm.response.to.have.status(200));",
                "const j = pm.response.json();",
                "if (j.success && j.data?.accessToken) {",
                "  pm.collectionVariables.set('access_token', j.data.accessToken);",
                "  pm.collectionVariables.set('refresh_token', j.data.refreshToken || '');",
                "  console.log('✅ access_token set!');",
                "} else if (j.success && j.data?.access_token) {",
                "  pm.collectionVariables.set('access_token', j.data.access_token);",
                "  pm.collectionVariables.set('refresh_token', j.data.refresh_token || '');",
                "  console.log('✅ access_token set!');",
                "} else {",
                "  console.log('❌ Token nahi mila. Full response:', JSON.stringify(j));",
                "}"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"9876543210\",\n  \"otp\": \"123456\",\n  \"fullName\": \"Test Driver\",\n  \"role\": \"driver\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/auth/verify-signup", "host": ["{{base_url}}"], "path": ["auth","verify-signup"] },
            "description": "OTP server logs mein milega.\nFields (validator se):\n- phone, otp (6 digits), role — sab required\n- fullName, email — optional"
          }
        },
        {
          "name": "Signin (existing user)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('200 OK', () => pm.response.to.have.status(200));",
                "console.log('OTP bheja gaya. Server logs dekho.');"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"9876543210\",\n  \"role\": \"driver\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/auth/signin", "host": ["{{base_url}}"], "path": ["auth","signin"] }
          }
        },
        {
          "name": "Verify Signin → TOKEN SET",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const j = pm.response.json();",
                "if (j.success && j.data?.accessToken) {",
                "  pm.collectionVariables.set('access_token', j.data.accessToken);",
                "  pm.collectionVariables.set('refresh_token', j.data.refreshToken || '');",
                "  console.log('✅ access_token set!');",
                "} else if (j.success && j.data?.access_token) {",
                "  pm.collectionVariables.set('access_token', j.data.access_token);",
                "  pm.collectionVariables.set('refresh_token', j.data.refresh_token || '');",
                "  console.log('✅ access_token set!');",
                "} else {",
                "  console.log('❌ Token nahi mila:', JSON.stringify(j));",
                "}"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"9876543210\",\n  \"otp\": \"123456\",\n  \"role\": \"driver\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/auth/verify-signin", "host": ["{{base_url}}"], "path": ["auth","verify-signin"] }
          }
        },
        {
          "name": "Refresh Token",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const j = pm.response.json();",
                "if (j.success && j.data?.accessToken) {",
                "  pm.collectionVariables.set('access_token', j.data.accessToken);",
                "  console.log('✅ Token refreshed!');",
                "}"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refresh_token}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/auth/refresh-token", "host": ["{{base_url}}"], "path": ["auth","refresh-token"] },
            "description": "Field name: refreshToken (camelCase — validator mein yahi hai)"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refresh_token}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/auth/logout", "host": ["{{base_url}}"], "path": ["auth","logout"] }
          }
        }
      ]
    },
    {
      "name": "KYC — Status (Driver only)",
      "item": [
        {
          "name": "GET KYC Status",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('200 OK', () => pm.response.to.have.status(200));",
                "const j = pm.response.json();",
                "pm.test('success true', () => pm.expect(j.success).to.be.true);",
                "if (j.data) {",
                "  console.log('kyc_status:', j.data.kyc_status);",
                "  console.log('aadhaar_status:', j.data.aadhaar_status);",
                "  console.log('pan_status:', j.data.pan_status);",
                "  console.log('bank_status:', j.data.bank_status);",
                "  console.log('dl_status:', j.data.dl_status);",
                "  console.log('rc_status:', j.data.rc_status);",
                "  console.log('face_status:', j.data.face_status);",
                "}"
              ]
            }
          }],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/kyc/status", "host": ["{{base_url}}"], "path": ["kyc","status"] }
          }
        }
      ]
    },
    {
      "name": "KYC — Aadhaar (Driver only)",
      "item": [
        {
          "name": "Step 1: Aadhaar OTP Bhejo",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('200 OK', () => pm.response.to.have.status(200));",
                "const j = pm.response.json();",
                "pm.test('success true', () => pm.expect(j.success).to.be.true);",
                "// Service returns { message, refId }",
                "if (j.data?.refId) {",
                "  pm.collectionVariables.set('aadhaar_ref_id', j.data.refId);",
                "  console.log('✅ refId saved:', j.data.refId);",
                "  console.log('Ab Step 2 chalao — OTP Aadhaar-linked mobile pe gaya hai');",
                "} else {",
                "  console.log('❌ refId missing. Response:', JSON.stringify(j));",
                "}",
                "// Agar already verified hai",
                "if (pm.response.code === 409) {",
                "  console.log('ℹ️ Aadhaar already verified hai is user ke liye');",
                "}"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"aadhaar_number\": \"655675523712\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/kyc/aadhaar/otp", "host": ["{{base_url}}"], "path": ["kyc","aadhaar","otp"] },
            "description": "Controller reads: req.body.aadhaar_number\nService returns: { message, refId }\n\nSandbox valid Aadhaar numbers: 655675523712, 655675523711\nMax 3 attempts allowed — uske baad manual_review."
          }
        },
        {
          "name": "Step 2: Aadhaar OTP Verify",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('200 OK', () => pm.response.to.have.status(200));",
                "const j = pm.response.json();",
                "pm.test('success true', () => pm.expect(j.success).to.be.true);",
                "if (j.success) {",
                "  console.log('✅ Aadhaar verified!');",
                "  console.log('aadhaar_status:', j.data?.aadhaar_status);",
                "  console.log('aadhaar_name:', j.data?.aadhaar_name);",
                "  console.log('aadhaar_dob:', j.data?.aadhaar_dob);",
                "  console.log('aadhaar_gender:', j.data?.aadhaar_gender);",
                "  console.log('aadhaar_state:', j.data?.aadhaar_state);",
                "  console.log('aadhaar_number_masked:', j.data?.aadhaar_number_masked);",
                "}"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ref_id\": \"{{aadhaar_ref_id}}\",\n  \"otp\": \"111000\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/kyc/aadhaar/verify", "host": ["{{base_url}}"], "path": ["kyc","aadhaar","verify"] },
            "description": "Controller reads: req.body.ref_id, req.body.otp\nref_id Step 1 se auto-fill hota hai.\n\nSandbox OTP: 111000 (fixed across all requests)\n\nCashfree response mein status === 'VALID' hona chahiye."
          }
        }
      ]
    },
