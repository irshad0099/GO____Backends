    {
      "name": "ADMIN — Manual Reviews",
      "item": [
        {
          "name": "List Manual Reviews",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const j = pm.response.json();",
                "if (pm.response.code === 403) {",
                "  console.log('ℹ️ Admin token chahiye. role=admin se signin karo.');",
                "  return;",
                "}",
                "pm.test('200 OK', () => pm.response.to.have.status(200));",
                "console.log('Pending manual reviews:', j.data?.length);",
                "if (j.data?.length > 0) {",
                "  j.data.forEach(r => {",
                "    console.log('user_id:', r.user_id, '| name:', r.full_name, '| phone:', r.phone_number);",
                "    console.log('  reason:', r.manual_review_reason);",
                "  });",
                "}"
              ]
            }
          }],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": {
              "raw": "{{base_url}}/kyc/admin/manual-reviews?page=1&limit=20",
              "host": ["{{base_url}}"],
              "path": ["kyc","admin","manual-reviews"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            },
            "description": "Requires role=admin token.\nReturns rider_kyc rows joined with users (full_name, phone_number)\nwhere kyc_status = 'manual_review'"
          }
        },
        {
          "name": "Resolve — APPROVE",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
